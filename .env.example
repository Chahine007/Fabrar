# ==============================================================================
# FABRAR ERP - Environment Variables Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# Variables marked with [REQUIRED] must be set for the application to start.

# ------------------------------------------------------------------------------
# 1. Server Configuration
# ------------------------------------------------------------------------------
# The port the Express server will listen on. (Default: 3000)
PORT=3000

# The external URL where the app is reachable. [REQUIRED]
# Used for Telegram webhooks and generating absolute links.
BASE_URL=https://gestionale.myfabdar.com

# Environment mode: development | production | test
NODE_ENV=development

# ------------------------------------------------------------------------------
# 2. Database Configuration (PostgreSQL)
# ------------------------------------------------------------------------------
# Prisma connection string. [REQUIRED]
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
PRISMA_DB_URL="postgresql://fabrar:fabrar_password@localhost:5432/fabrar_erp?schema=public"

# Database Connection Pool Settings (Optional)
PG_POOL_MAX=10
PG_POOL_IDLE_MS=10000
PG_POOL_CONNECT_TIMEOUT_MS=10000

# Docker-specific PostgreSQL settings (if using docker-compose)
POSTGRES_USER=fabrar
POSTGRES_PASSWORD=fabrar_password
POSTGRES_DB=fabrar_erp

# ------------------------------------------------------------------------------
# 3. Authentication & Security
# ------------------------------------------------------------------------------
# Secret key for signing JWT tokens. [REQUIRED]
# Use a long, random string.
JWT_SECRET=una_password_segreta_molto_lunga_e_casuale

# Google Client ID for OAuth2.
GOOGLE_CLIENT_ID=incolla_qui_il_tuo_id_client

# Secret token for Telegram Webhook security. [REQUIRED]
# This is a custom string to verify that requests are coming from Telegram.
TELEGRAM_SECRET=your-custom-telegram-webhook-secret

# ------------------------------------------------------------------------------
# 4. Third-Party API Integrations
# ------------------------------------------------------------------------------
# Telegram Bot API Token from @BotFather. [REQUIRED]
TELEGRAM_BOT_TOKEN=123456789:ABCDEF_GHIJKL_MNOPQRSTUVWXYZ

# OpenAI API Key for intelligent report processing. [REQUIRED]
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# 5. Initial Setup / Admin Credentials
# ------------------------------------------------------------------------------
# Default credentials for the dashboard (if used during setup/dev).
DASH_USER=user
DASH_PASS=change-me

# Initial Admin user to be created or recognized by the system.
ADMIN_USER=admin
ADMIN_PASS=admin-password
ADMIN_EMPLOYEE_ID=1

# ------------------------------------------------------------------------------
# 6. Localization, Logging & Backups
# ------------------------------------------------------------------------------
# System timezone. (Default: Europe/Rome)
TIMEZONE=Europe/Rome

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Directory for database backups.
DB_BACKUP_DIR=./backups
